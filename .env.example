# ─────────────────────────────────────────────────────────────────
# AI Student Productivity Agent — Environment Variables
# Copy this file to ".env" and fill in your real credentials.
# NEVER commit the real .env file to version control.
# ─────────────────────────────────────────────────────────────────

# IBM watsonx.ai credentials
# Get from: https://cloud.ibm.com/iam/apikeys
IBM_API_KEY=

# watsonx.ai base URL (region-specific)
# e.g. https://us-south.ml.cloud.ibm.com
IBM_URL=

# Your watsonx.ai project ID (from the project settings page)
IBM_PROJECT_ID=your_project_id_here

# Optional: override the model (default: ibm/granite-13b-instruct-v2)
# IBM_MODEL_ID=ibm/granite-13b-instruct-v2

# Set to "true" for hot-reload during development
FLASK_DEBUG=false
